## Odchudzona lista .gitignore (Visual Studio + Python + VS Code)
## Na podstawie: https://github.com/github/gitignore/blob/main/VisualStudio.gitignore

# --- Sekcja Python & Środowisko ---
.venv/
venv/
ENV/
env/
.env
**/__pycache__/
*.py[cod]
*$py.class
*.pyc
*.sqlite3

# --- Foldery lokalne / Media ---
static/
media/

# --- CSV file
products.csv

# --- Systemowe (macOS) ---
.DS_Store
.AppleDouble
.LSOverride
**/._*
.Spotlight-V100
.Trashes

# --- Pliki graficzne (specyficzne dla projektu) ---
co*generatora.png
co*glowna*.png
podzial*generatora.png

# --- Visual Studio: Pliki użytkownika i Cache ---
.vs/
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates
*.userprefs
mono_crash.*
*.aps
*.ncb
*.opendb
*.opensdf
*.sdf
*.cachefile
*.VC.db
*.VC.VC.opendb

# --- Visual Studio: Build & Output ---
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
[Aa][Rr][Mm]64[Ee][Cc]/
bld/
[Oo]bj/
[Oo]ut/
[Ll]og/
[Ll]ogs/
**/[Bb]in/*
Generated\ Files/

# --- Testy (MSTest, NUnit, Coverlet) ---
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*
*.trx
*.VisualState.xml
TestResult.xml
nunit-*.xml
*.received.*
coverage*.json
coverage*.xml
coverage*.info
*.coverage
*.coveragexml

# --- Rozszerzenia (ReSharper, Web Workbench, etc.) ---
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user
.sass-cache/
_Chutzpah*
BenchmarkDotNet.Artifacts/

# --- Narzędzia Web & Azure ---
node_modules/
.ntvs_analysis.dat
publish/
*.[Pp]ublish.xml
*.azurePubxml
*.pubxml
*.publishproj
PublishScripts/
csx/
*.build.csdef
ecf/
rcf/

# --- NuGet ---
*.nupkg
*.snupkg
**/[Pp]ackages/*
!**/[Pp]ackages/build/
*.nuget.props
*.nuget.targets

# --- VS Code (z zachowaniem ważnych ustawień) ---
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/*.code-snippets
.history/
*.vsix

# --- Bazy danych SQL Server ---
*.mdf
*.ldf
*.ndf

# --- Inne / Tymczasowe ---
~$*
*~
*.log
*.tmp
*.bak
*.binlog
.aws-sam
.localhistory/